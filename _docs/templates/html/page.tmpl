{{ define "page" }}
<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        {{ if .Page.Description }}<meta name="description" content="{{ .Page.Description }}" />{{ else }}<meta name="description" content="{{ .Site.Description }}" />{{ end }}
        <title>{{ if .Page.Title }}{{ .Page.Title }} | {{ end }}{{ .Site.Title }}</title>
        <link rel="stylesheet" href="/style.css" />
    </head>
    <body>
        <div class="shell">
            <header class="site-header">
                <pre class="banner" aria-label="shizuka">░█▀▀░█░█░▀█▀░▀▀█░█░█░█░█░█▀█
░▀▀█░█▀█░░█░░▄▀░░█░█░█▀▄░█▀█
░▀▀▀░▀░▀░▀▀▀░▀▀▀░▀▀▀░▀░▀░▀░▀</pre>
                <p>{{ .Site.Description }}</p>
            </header>

            <div class="layout">
                <nav class="nav" aria-label="Documentation">
                    <a {{ if eq .Page.Path "/" }}aria-current="page"{{ end }} href="/">overview</a>
                    <a {{ if eq .Page.Path "/site-structure/" }}aria-current="page"{{ end }} href="/site-structure/">site structure</a>
                    <a {{ if eq .Page.Path "/config/" }}aria-current="page"{{ end }} href="/config/">config</a>
                    <a {{ if eq .Page.Path "/frontmatter/" }}aria-current="page"{{ end }} href="/frontmatter/">frontmatter</a>
                    <a {{ if eq .Page.Path "/templates/" }}aria-current="page"{{ end }} href="/templates/">templates</a>
                    <a {{ if eq .Page.Path "/scaffolds/" }}aria-current="page"{{ end }} href="/scaffolds/">scaffolds</a>
                    <a {{ if eq .Page.Path "/build-step-dag/" }}aria-current="page"{{ end }} href="/build-step-dag/">build dag</a>
                </nav>

                <main class="content">
                    <header class="page-title">
                        <p>{{ .Page.Path }}</p>
                        <h1>{{ .Page.Title }}</h1>
                        {{ if .Page.Description }}<p>{{ .Page.Description }}</p>{{ end }}
                    </header>
                    {{ .Page.Body }}
                </main>
            </div>
        </div>
    </body>
</html>
{{ end }}
